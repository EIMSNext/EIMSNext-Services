{
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Quartz": "Warning",
                "Microsoft": "Warning",
                "EIMSNext.Async.Core": "Information"
            }
        },
        "Enrich": [ "FromLogContext", "WithProperty" ],
        "Properties": {
            "Application": "EIMSNext.Async.Host"
        },
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            },
            {
                "Name": "File",
                "Args": {
                    "path": "Logs/log-.txt",
                    "rollingInterval": "Day",
                    "retainedFileCountLimit": 31,
                    "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff zzz}] [{Level:u3}] {Message:lj}{NewLine}{Exception}"
                }
            }
        ]
    },
    "MongoDb": {
        "ConnectionString": "mongodb://localhost:27017",
        "Database": "EIMS"
    },
    "Storage": {
        //"BaseUrl": "http://localhost:9999/jlupload/api/v1"
        "BaseUrl": "http://localhost:9999/JLUpload",
        "LocalPath": "D:\\WebSites\\Upload\\wwwroot"
    },
    "CacheServer": {
        "EndPoint": "localhost:6379",
        "Database": 1
    },
    "RabbitMQ": {
        "HostName": "localhost",
        "UserName": "guest",
        "Password": "guest"
    },
    "Quartz": {
        "ConnectionString": "Server=.;Database=Quartz;User Id=quartz_user;Password=sa@123;TrustServerCertificate=True;Encrypt=false;"
    }
}
